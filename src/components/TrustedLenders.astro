---
const pngGlob = import.meta.glob('../../resources/logos/marquee/*.png', {
	eager: true,
	query: '?url',
	import: 'default',
}) as Record<string, string>;

const icoGlob = import.meta.glob('../../resources/logos/marquee/*.ico', {
	eager: true,
	query: '?url',
	import: 'default',
}) as Record<string, string>;

const bySlug: Record<string, string> = {};
for (const [path, url] of Object.entries({ ...pngGlob, ...icoGlob })) {
	const slug = path
		.replace(/^.*[\\/]/, '')
		.replace(/\.(png|ico|svg|webp)$/i, '');
	bySlug[slug] = url;
}

/** Big four + major regionals + widely used business / specialist lenders (AU). */
const ORDER = [
	'cba',
	'westpac',
	'nab',
	'anz',
	'macquarie',
	'stgeorge',
	'bankwest',
	'bendigo',
	'boq',
	'ing',
	'suncorp',
	'prospa',
	'ondeck',
	'banjo',
	'capify',
	'bizcap',
	'lumi',
	'moula',
	'finstro',
	'fundsnow',
	'scotpac',
	'nimble',
	'pepper',
	'liberty',
	'trucap',
] as const;

const ALT: Record<string, string> = {
	cba: 'Commonwealth Bank',
	westpac: 'Westpac',
	nab: 'NAB',
	anz: 'ANZ',
	macquarie: 'Macquarie',
	stgeorge: 'St.George Bank',
	bankwest: 'Bankwest',
	bendigo: 'Bendigo Bank',
	boq: 'Bank of Queensland',
	ing: 'ING',
	suncorp: 'Suncorp Bank',
	prospa: 'Prospa',
	ondeck: 'OnDeck',
	banjo: 'Banjo Loans',
	capify: 'Capify',
	bizcap: 'Bizcap',
	lumi: 'Lumi',
	moula: 'Moula',
	finstro: 'Finstro',
	fundsnow: 'Funds Now',
	scotpac: 'ScotPac',
	nimble: 'Nimble',
	pepper: 'Pepper Money',
	liberty: 'Liberty',
	trucap: 'Trucap',
};

const lenders = ORDER.filter((slug) => bySlug[slug]).map((slug) => ({
	name: ALT[slug] ?? slug,
	src: bySlug[slug],
}));
---

<section
	class="relative border-b border-brand/10 py-16 sm:py-24"
	style="background-color: #f5f7fa; background-image: radial-gradient(rgba(0, 58, 143, 0.08) 1px, transparent 1px); background-size: 20px 20px;"
	aria-labelledby="trusted-lenders-heading"
>
	<div class="mx-auto max-w-6xl px-4 sm:px-6">
		<h2
			id="trusted-lenders-heading"
			class="font-display mx-auto max-w-4xl text-center text-2xl font-bold leading-snug tracking-tight text-fg sm:text-3xl md:text-4xl"
		>
			<span class="block">
				Some Of The{' '}
				<span class="inline-block rounded-sm bg-cta px-2 py-0.5 text-white sm:px-3 sm:py-1">Trusted Lenders</span>
			</span>
			<span class="mt-2 block sm:mt-3">We Work With:</span>
		</h2>

		<p class="mx-auto mt-3 max-w-2xl text-center text-sm text-fg-muted">
			Major banks, regional banks, and specialist business lenders — shown for illustration; actual availability depends on your scenario.
		</p>

		<div class="relative mt-12">
			<div
				class="pointer-events-none absolute inset-y-0 left-0 z-10 w-12 bg-gradient-to-r from-[#f5f7fa] to-transparent sm:w-20"
				aria-hidden="true"
			/>
			<div
				class="pointer-events-none absolute inset-y-0 right-0 z-10 w-12 bg-gradient-to-l from-[#f5f7fa] to-transparent sm:w-20"
				aria-hidden="true"
			/>
			<div class="overflow-hidden py-2">
				<div class="trusted-marquee-track">
					<div class="trusted-marquee-set flex shrink-0 items-center gap-10 pr-10 sm:gap-14 sm:pr-14 md:gap-16">
						{
							lenders.map((l) => (
								<img
									src={l.src}
									alt={l.name}
									width="160"
									height="64"
									loading="lazy"
									decoding="async"
									draggable="false"
									class="h-11 w-auto max-w-[9rem] shrink-0 object-contain object-center sm:h-12 md:h-14"
								/>
							))
						}
					</div>
					<div
						class="trusted-marquee-set trusted-marquee-dupe flex shrink-0 items-center gap-10 pr-10 sm:gap-14 sm:pr-14 md:gap-16"
						aria-hidden="true"
					>
						{
							lenders.map((l) => (
								<img
									src={l.src}
									alt=""
									width="160"
									height="64"
									loading="lazy"
									decoding="async"
									draggable="false"
									class="h-11 w-auto max-w-[9rem] shrink-0 object-contain object-center sm:h-12 md:h-14"
								/>
							))
						}
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
