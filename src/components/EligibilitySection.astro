---
import EligibilityWizard from './EligibilityWizard';
---

<section
	id="check-eligibility"
	class="scroll-mt-20 border-t border-brand/15 bg-gradient-to-b from-page via-surface-subtle to-page py-20 sm:py-28"
	aria-labelledby="eligibility-heading"
>
	<div class="mx-auto max-w-2xl px-4 sm:px-6">
		<h2 id="eligibility-heading" class="font-display text-center text-3xl font-bold tracking-tight text-brand sm:text-4xl">
			Check your eligibility
		</h2>
		<p class="mx-auto mt-4 max-w-lg text-center text-fg-muted">
			Answer a few questions — about 60 seconds. No credit check to see if we can help.
		</p>
		<div class="mt-10">
			<EligibilityWizard client:load />
		</div>
	</div>
</section>
