<section class="relative overflow-hidden border-b border-brand/15">
	<!-- Generated banner: parrot-green abstract, subtle coin/bokeh (see /public/hero-banner.png) -->
	<div
		class="pointer-events-none absolute inset-0 bg-cover bg-center bg-no-repeat"
		style="background-image: url('/hero-banner.png');"
		aria-hidden="true"
	/>
	<!-- Light wash only — keeps coin/banner art visible; stronger at bottom for contrast -->
	<div
		class="pointer-events-none absolute inset-0 bg-gradient-to-b from-page/35 via-page/20 to-page/45"
		aria-hidden="true"
	/>
	<div
		class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_90%_60%_at_50%_-25%,rgb(34_197_94/0.08),transparent_55%)]"
		aria-hidden="true"
	/>
	<div
		class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_70%_45%_at_100%_0%,rgb(22_101_52/0.06),transparent_50%)]"
		aria-hidden="true"
	/>
	<div class="relative z-10 mx-auto max-w-6xl px-4 pb-20 pt-16 text-center sm:px-6 sm:pt-24 md:pb-28">
		<p
			class="mb-4 text-sm font-medium uppercase tracking-widest text-brand-secondary [text-shadow:0_1px_0_rgb(255_255_255/0.75)]"
		>
			Australian businesses
		</p>
		<h1
			class="font-display mx-auto max-w-3xl text-4xl font-bold leading-[1.1] tracking-tight text-brand [text-shadow:0_1px_0_rgb(255_255_255/0.85),0_6px_28px_rgb(240_253_244/0.55)] sm:text-5xl md:text-6xl"
		>
			Funding options without the bank runaround
		</h1>
		<p
			class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-fg-muted [text-shadow:0_1px_0_rgb(255_255_255/0.7)]"
		>
			Tell us what you need. We match you with suitable lenders, keep paperwork light, and move
			quickly—so you can get back to running the business.
		</p>
		<div class="mt-10 flex flex-wrap items-center justify-center gap-4">
			<a
				href="#check-eligibility"
				class="inline-flex items-center justify-center rounded-full bg-cta px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand/35 transition hover:brightness-110"
			>
				Start in 60 seconds
			</a>
			<a
				href="#how"
				class="inline-flex items-center justify-center rounded-full border-2 border-brand-secondary/50 bg-surface/80 px-8 py-3.5 text-base font-semibold text-brand-secondary backdrop-blur-sm transition hover:border-brand-secondary hover:bg-surface-subtle"
			>
				See how it works
			</a>
		</div>
		<dl class="mt-16 grid gap-8 border-t border-brand/15 pt-12 sm:grid-cols-3">
			<div class="text-center">
				<dt class="text-sm text-fg-muted">Typical response</dt>
				<dd class="mt-1 font-display text-2xl font-semibold text-brand">Same day</dd>
			</div>
			<div class="text-center">
				<dt class="text-sm text-fg-muted">Credit check</dt>
				<dd class="mt-1 font-display text-2xl font-semibold text-brand">Not upfront</dd>
			</div>
			<div class="text-center">
				<dt class="text-sm text-fg-muted">Your obligation</dt>
				<dd class="mt-1 font-display text-2xl font-semibold text-brand">None until you proceed</dd>
			</div>
		</dl>
	</div>
</section>
