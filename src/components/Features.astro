---
const items = [
	{
		title: 'Speed',
		body: 'Structured so decisions and documents don’t sit in limbo for weeks.',
	},
	{
		title: 'Low-doc paths',
		body: 'Where the situation allows, we prioritise bank statements and essentials over full packs.',
	},
	{
		title: 'Broad lender set',
		body: 'Access non-bank and specialist programs suited to trading businesses—not one-size products.',
	},
	{
		title: 'Plain language',
		body: 'Rates, fees, and repayment mechanics explained up front so you can compare properly.',
	},
];
---

<section
	id="options"
	class="scroll-mt-20 bg-gradient-to-b from-surface-subtle via-surface to-page py-20 sm:py-28"
>
	<div class="mx-auto max-w-6xl px-4 sm:px-6">
		<h2 class="font-display text-3xl font-bold tracking-tight text-brand sm:text-4xl">
			Built for operators
		</h2>
		<p class="mt-4 max-w-2xl text-lg text-fg-muted">
			What you get when the process is designed around business reality, not branch policy manuals.
		</p>
		<ul class="mt-14 grid gap-6 sm:grid-cols-2">
			{items.map((item) => (
				<li class="group rounded-2xl border border-brand/12 bg-surface/90 p-8 shadow-sm shadow-brand/5 transition hover:border-brand-secondary/35 hover:shadow-md">
					<h3 class="font-display text-lg font-semibold text-brand">{item.title}</h3>
					<p class="mt-3 text-sm leading-relaxed text-fg-muted">{item.body}</p>
				</li>
			))}
		</ul>
	</div>
</section>
