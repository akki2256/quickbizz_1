---
const legalLinks = [
	{ href: '/about', label: 'About Us' },
	{ href: '/privacy', label: 'Privacy Policy' },
	{ href: '/credit-guide', label: 'Credit Guide' },
	{ href: '/terms', label: 'Terms & Conditions' },
	{ href: '/security', label: 'Security' },
	{ href: '/contact', label: 'Contact Us' },
] as const;
---

<div class="border-t border-white/10 bg-[#0d4d57] text-white">
	<div class="mx-auto max-w-6xl px-4 py-4 sm:px-6 sm:py-5">
		<nav
			class="flex flex-wrap items-center justify-center gap-x-1 gap-y-2 text-center text-sm font-semibold tracking-tight sm:text-base"
			aria-label="Legal and information"
		>
			{
				legalLinks.flatMap((link, i) =>
					i === 0
						? [
								<a
									href={link.href}
									class="px-1.5 text-white transition hover:text-white hover:underline hover:underline-offset-4"
								>
									{link.label}
								</a>,
							]
						: [
								<span class="select-none px-1.5 text-white/45 sm:px-2" aria-hidden="true">|</span>,
								<a
									href={link.href}
									class="px-1.5 text-white transition hover:text-white hover:underline hover:underline-offset-4"
								>
									{link.label}
								</a>,
							],
				)
			}
		</nav>
	</div>
</div>
