	<div class="mx-auto flex max-w-6xl flex-col gap-6 px-4 sm:flex-row sm:items-center sm:justify-between sm:px-6">
		<p class="font-display text-sm font-semibold text-white">
			Quick<span class="text-cta">Biz</span>
		</p>
		<p class="text-sm text-white/80">
			© {year} QuickBiz. Australian Credit Licence disclosure and target-market statements apply to credit
			assistance—replace with your actual licensing text before launch.
		</p>
	</div>
</footer>
