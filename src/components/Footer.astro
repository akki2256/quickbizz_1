---
import { siteNavLinks } from '../lib/siteNav';

const year = new Date().getFullYear();

/** Replace `href` with your real profile URLs when ready. */
const socialLinks = [
	{
		label: 'LinkedIn',
		href: 'https://www.linkedin.com/',
	},
	{
		label: 'Facebook',
		href: 'https://www.facebook.com/',
	},
	{
		label: 'Instagram',
		href: 'https://www.instagram.com/',
	},
] as const;
---

<footer class="border-t border-brand/30 bg-brand text-white">
	<div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
		<div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-12 lg:gap-8">
			<div class="lg:col-span-4">
				<a href="/" class="inline-block font-display text-lg font-semibold text-white">
					Quick<span class="text-cta">Biz</span>
				</a>
			</div>

			<nav class="lg:col-span-4" aria-label="Footer">
				<p class="text-xs font-semibold uppercase tracking-wider text-white/60">Menu</p>
				<ul class="mt-4 flex flex-col gap-2.5 text-sm">
					{siteNavLinks.map((item) => (
						<li>
							<a
								href={item.href}
								class="text-white/90 transition hover:text-white hover:underline hover:decoration-cta hover:underline-offset-4"
							>
								{item.label}
							</a>
						</li>
					))}
				</ul>
			</nav>

			<div class="sm:col-span-2 lg:col-span-4">
				<p class="text-xs font-semibold uppercase tracking-wider text-white/60">Social</p>
				<ul class="mt-4 flex flex-wrap items-center gap-3">
					{socialLinks.map((s) => (
						<li>
							<a
								href={s.href}
								target="_blank"
								rel="noopener noreferrer"
								class="flex h-10 w-10 items-center justify-center rounded-full border border-white/20 bg-white/5 text-white transition hover:border-white/40 hover:bg-white/10"
								aria-label={s.label}
							>
								{s.label === 'LinkedIn' && (
									<svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
										<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
									</svg>
								)}
								{s.label === 'Facebook' && (
									<svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
										<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
									</svg>
								)}
								{s.label === 'Instagram' && (
									<svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
										<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
									</svg>
								)}
							</a>
						</li>
					))}
				</ul>
			</div>
		</div>

		<div
			class="mt-10 flex flex-col gap-4 border-t border-white/15 pt-8 sm:flex-row sm:items-center sm:justify-between"
		>
			<p class="text-sm text-white/80">
				© {year} QuickBiz. Australian Credit Licence disclosure and target-market statements apply to credit
				assistance—replace with your actual licensing text before launch.
			</p>
			<nav class="flex flex-wrap gap-x-6 gap-y-2 text-sm" aria-label="Legal">
				<a href="/privacy" class="text-white/85 transition hover:text-white hover:underline hover:underline-offset-4">
					Privacy policy
				</a>
				<a href="/terms" class="text-white/85 transition hover:text-white hover:underline hover:underline-offset-4">
					Terms &amp; conditions
				</a>
			</nav>
		</div>
	</div>
</footer>
