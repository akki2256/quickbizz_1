---
const steps = [
	{
		icon: 'survey' as const,
		title: 'Short survey',
		body: 'Share your situation and what you need—takes about a minute. No upfront credit hit to explore options.',
	},
	{
		icon: 'phone' as const,
		title: 'Speak to a specialist',
		body: 'We clarify details, answer questions, and align you with lenders that fit your profile.',
	},
	{
		icon: 'compare' as const,
		title: 'Compare & proceed',
		body: 'Review tailored options on your timeline. Move forward only when the terms work for you.',
	},
];
---

<section
	id="how"
	class="scroll-mt-20 border-b border-brand/10 bg-gradient-to-b from-page to-surface-subtle py-20 sm:py-28"
>
	<div class="mx-auto max-w-6xl px-4 sm:px-6">
		<h2 class="font-display text-center text-3xl font-bold tracking-tight text-brand sm:text-4xl">
			How it works
		</h2>
		<p class="mx-auto mt-4 max-w-2xl text-center text-lg text-fg-muted">
			A straight path from enquiry to clarity—without drowning in paperwork first.
		</p>

		<div
			class="mt-14 flex flex-col gap-6 md:flex-row md:items-stretch md:justify-center md:gap-0"
			role="list"
		>
			{
				steps.map((s, i) => (
					<>
						<div
							class="flex-1 rounded-2xl border border-brand/15 bg-surface p-8 shadow-md shadow-brand/5"
							role="listitem"
						>
							<div class="flex items-center gap-3">
								<div
									class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-brand/10 text-brand"
									aria-hidden="true"
								>
									{s.icon === 'survey' && (
										<svg
											class="h-6 w-6"
											xmlns="http://www.w3.org/2000/svg"
											fill="none"
											viewBox="0 0 24 24"
											stroke-width="1.5"
											stroke="currentColor"
										>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.065 4.072 8.25 4.992 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"
											/>
										</svg>
									)}
									{s.icon === 'phone' && (
										<svg
											class="h-6 w-6"
											xmlns="http://www.w3.org/2000/svg"
											fill="none"
											viewBox="0 0 24 24"
											stroke-width="1.5"
											stroke="currentColor"
										>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
											/>
										</svg>
									)}
									{s.icon === 'compare' && (
										<svg
											class="h-6 w-6"
											xmlns="http://www.w3.org/2000/svg"
											fill="none"
											viewBox="0 0 24 24"
											stroke-width="1.5"
											stroke="currentColor"
										>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"
											/>
										</svg>
									)}
								</div>
							</div>
							<h3 class="mt-4 font-display text-xl font-semibold text-fg">{s.title}</h3>
							<p class="mt-3 text-sm leading-relaxed text-fg-muted">{s.body}</p>
						</div>
						{i < steps.length - 1 && (
							<div
								class="flex shrink-0 items-center justify-center py-4 md:px-2 md:py-0 lg:px-4"
								aria-hidden="true"
							>
								<svg
									class="h-9 w-9 rotate-90 text-brand-secondary md:h-10 md:w-10 md:rotate-0"
									xmlns="http://www.w3.org/2000/svg"
									fill="none"
									viewBox="0 0 24 24"
									stroke-width="1.5"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
									/>
								</svg>
							</div>
						)}
					</>
				))
			}
		</div>
	</div>
</section>
