---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export const prerender = true;
---

<Layout title="About us — QuickBiz" description="Learn about QuickBiz.">
	<Header />
	<main>
		<section class="border-b border-brand/10 bg-gradient-to-b from-page to-surface-subtle py-16 sm:py-24">
			<div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
				<h1 class="font-display text-3xl font-bold tracking-tight text-brand sm:text-4xl">About us</h1>
				<p class="mx-auto mt-6 max-w-2xl text-lg text-fg-muted">
					This page will introduce QuickBiz, your team, and how you help Australian businesses. Replace this
					placeholder with your story, credentials, and compliance disclosures as needed.
				</p>
			</div>
		</section>
	</main>
	<Footer />
</Layout>
