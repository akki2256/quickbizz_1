---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import privacyPolicyHtml from '../content/legal/privacy-policy.html?raw';

export const prerender = true;
---

<Layout title="Privacy policy — QuickBiz" description="QuickBiz privacy policy.">
	<Header />
	<main>
		<section class="border-b border-brand/10 bg-gradient-to-b from-page to-surface-subtle py-12 sm:py-16">
			<div class="mx-auto max-w-3xl px-4 sm:px-6">
				<div set:html={privacyPolicyHtml} />
			</div>
		</section>
	</main>
	<Footer />
</Layout>
