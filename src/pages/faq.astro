---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export const prerender = true;

const faqs = [
	{
		q: 'What is QuickBiz?',
		a: 'QuickBiz helps Australian businesses explore funding options with a short eligibility check and specialist support. This is placeholder copy you can replace anytime.',
	},
	{
		q: 'Does checking eligibility affect my credit score?',
		a: 'Placeholder answer — describe your actual process (e.g. soft vs hard checks) here.',
	},
	{
		q: 'How long does approval take?',
		a: 'Placeholder — typical timeframes vary by product and lender. Update with your real guidance.',
	},
	{
		q: 'What documents will I need?',
		a: 'Placeholder — e.g. bank statements, ID, BAS. Replace with your standard checklist.',
	},
	{
		q: 'Is there a cost for the initial conversation?',
		a: 'Placeholder — clarify whether initial consults are free and how fees work for credit assistance.',
	},
];
---

<Layout title="FAQs — QuickBiz" description="Frequently asked questions about QuickBiz.">
	<Header />
	<main>
		<section class="border-b border-brand/10 bg-gradient-to-b from-page to-surface-subtle py-16 sm:py-24">
			<div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
				<h1 class="font-display text-3xl font-bold tracking-tight text-brand sm:text-4xl">FAQs</h1>
				<p class="mx-auto mt-4 max-w-2xl text-fg-muted">
					Answers below are placeholders — swap in your final content when ready.
				</p>
				<div class="mt-10 flex flex-col gap-3 text-left">
					{faqs.map((item) => (
						<details
							class="group rounded-2xl border border-brand/12 bg-surface/90 shadow-sm shadow-brand/5 open:border-brand-secondary/30 open:shadow-md"
						>
							<summary class="cursor-pointer list-none px-5 py-4 font-display font-semibold text-brand transition marker:content-none [&::-webkit-details-marker]:hidden">
								<span class="flex items-center justify-between gap-3">
									{item.q}
									<span
										class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-brand/15 bg-surface-subtle text-lg leading-none text-brand-secondary transition group-open:rotate-180"
										aria-hidden="true"
									>
										↓
									</span>
								</span>
							</summary>
							<div class="border-t border-brand/10 px-5 pb-5 pt-0">
								<p class="pt-4 text-sm leading-relaxed text-fg-muted">{item.a}</p>
							</div>
						</details>
					))}
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>
